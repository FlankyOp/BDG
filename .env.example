# Environment Variables Template
# Copy this to .env (or set as Railway environment variables)
# DO NOT commit .env file - it's ignored by git

# Firebase Service Account Path
# On local: path to firebase-adminsdk.json
# On Railway: /app/firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_PATH=bdg_predictor/firebase-adminsdk.json

# API Settings
BDG_API_BASE_URL=https://draw.ar-lottery01.com
BDG_API_TIMEOUT=10
BDG_GAME_CODE=WinGo_1M

# Polling Settings
BDG_DEFAULT_POLLING_INTERVAL=30
BDG_HISTORY_DRAWS_LIMIT=500

# Logging
BDG_LOG_DIR=logs
BDG_LOG_LEVEL=INFO

# LSTM Model
BDG_LSTM_ENABLED=true
BDG_LSTM_MODEL_DIR=bdg_predictor/models

# Self-Learning
BDG_ENABLE_SELF_LEARNING=true
BDG_LEARNING_RATE=0.08
